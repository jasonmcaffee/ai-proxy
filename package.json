{
  "name": "ai-proxy",
  "version": "0.0.1",
  "description": "OpenAI-compatible proxy for llama.cpp with context compression, retry, and tool-call buffering",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "stop-service": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 4142 -State Listen -ErrorAction SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { Stop-Process -Id $p -Force; Write-Host 'Killed process' $p } else { Write-Host 'No process on port 4142' }\"",
    "stop-service-prod": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 4141 -State Listen -ErrorAction SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { Stop-Process -Id $p -Force; Write-Host 'Killed process' $p } else { Write-Host 'No process on port 4141' }\"",
    "build-and-deploy": "powershell -ExecutionPolicy Bypass -File scripts/build-and-deploy.ps1",
    "start": "set PORT=4142&&nest start",
    "start:dev": "set PORT=4142&&nest start --watch",
    "start:debug": "set PORT=4142&&nest start --debug --watch",
    "start:prod": "set PORT=4141&&node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:all": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate-ai-client-win": "npx openapi-generator-cli generate -i src/openapi-spec.json -g typescript-fetch -o ./client --additional-properties=useSingleRequestParameter=false",
    "generate-client": "npx ts-node -r tsconfig-paths/register scripts/rewrite-spec-names.ts && npx openapi-generator-cli generate -i src/openapi-spec.rewritten.json -g typescript-fetch -o ./client/generated --additional-properties=useSingleRequestParameter=false"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "openai": "^6.34.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@openapitools/openapi-generator-cli": "^2.16.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ]
  }
}
