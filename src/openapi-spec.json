  "info": {
    "title": "AI Proxy API",
    "description": "OpenAI-compatible proxy for llama.cpp with context compression, retry, and tool-call buffering",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "FunctionCallDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "arguments": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "ToolCallDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "example": "function"
          },
          "function": {
            "$ref": "#/components/schemas/FunctionCallDto"
          }
        },
        "required": [
          "id",
          "type",
          "function"
        ]
      },
      "ChatMessageDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "example": "user",
            "description": "Role of the message sender: system, user, assistant, or tool"
          },
          "content": {
            "type": "string",
            "description": "Message content (string for text, array for multimodal/vision)"
          },
          "tool_calls": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolCallDto"
            }
          },
          "tool_call_id": {
            "type": "string"
          },
          "reasoning_content": {
            "type": "string",
            "description": "Reasoning content from llama.cpp thinking models (non-standard OpenAI field)"
          }
        },
        "required": [
          "role"
        ]
      },
      "ToolFunctionDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          }
        },
        "required": [
          "name"
        ]
      },
      "ToolDefinitionDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "function"
          },
          "function": {
            "$ref": "#/components/schemas/ToolFunctionDto"
          }
        },
        "required": [
          "type",
          "function"
        ]
      },
      "CompressionOptionsDto": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable context compression before forwarding to llama.cpp"
          },
          "maxContextSize": {
            "type": "number",
            "description": "Maximum context size in tokens. Older messages are evicted when exceeded."
          }
        }
      },
      "ChatCompletionRequestDto": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessageDto"
            }
          },
          "model": {
            "type": "string"
          },
          "temperature": {
            "type": "number"
          },
          "stream": {
            "type": "boolean"
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolDefinitionDto"
            }
          },
          "tool_choice": {
            "type": "object"
          },
          "max_tokens": {
            "type": "number"
          },
          "compressionOptions": {
            "description": "Proxy extension: context compression options",
            "allOf": [
              {
                "$ref": "#/components/schemas/CompressionOptionsDto"
              }
            ]
          },
          "awaitToolCallCompletion": {
            "type": "boolean",
            "description": "Proxy extension: buffer all tool-call deltas before sending to client (only meaningful when stream=true)"
          }
        },
        "required": [
          "messages"
        ]
      },
      "ChatChoiceDto": {
        "type": "object",
        "properties": {
          "index": {
            "type": "number"
          },
          "message": {
            "$ref": "#/components/schemas/ChatMessageDto"
          },
          "finish_reason": {
            "type": "string"
          }
        },
        "required": [
          "index",
          "message"
        ]
      },
      "UsageDto": {
        "type": "object",
        "properties": {
          "prompt_tokens": {
            "type": "number"
          },
          "completion_tokens": {
            "type": "number"
          },
          "total_tokens": {
            "type": "number"
          }
        },
        "required": [
          "prompt_tokens",
          "completion_tokens",
          "total_tokens"
        ]
      },
      "ChatCompletionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "chat.completion"
          },
          "created": {
            "type": "number"
          },
          "model": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatChoiceDto"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/UsageDto"
          }
        },
        "required": [
          "id",
          "object",
          "created",
          "model",
          "choices"
        ]
      },
      "ModelObjectDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "local-model"
          },
          "object": {
            "type": "string",
            "example": "model"
          },
          "created": {
            "type": "number"
          },
          "owned_by": {
            "type": "string",
            "example": "llama.cpp"
          }
        },
        "required": [
          "id",
          "object",
          "created",
          "owned_by"
        ]
      },
      "ModelsListResponseDto": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "example": "list"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelObjectDto"
            }
          }
        },
        "required": [
          "object",
          "data"
        ]
      }
    }
  }
}